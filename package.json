{
  "name": "claude-task-alert",
  "version": "1.1.0",
  "description": "Get Slack notifications when Claude Code stops and needs your attention — zero-config Slack app setup via interactive CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-task-alert": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "slack",
    "notifications",
    "alerts",
    "cli",
    "hooks",
    "developer-tools",
    "productivity"
  ],
  "author": "singhsameer2891-pixel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/singhsameer2891-pixel/claude-task-alert.git"
  },
  "bugs": {
    "url": "https://github.com/singhsameer2891-pixel/claude-task-alert/issues"
  },
  "homepage": "https://github.com/singhsameer2891-pixel/claude-task-alert#readme",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "open": "^11.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
