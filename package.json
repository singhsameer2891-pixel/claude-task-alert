{
  "name": "claude-ping",
  "version": "2.0.0",
  "description": "Play a sound on your laptop when Claude Code stops and needs your attention — zero-config interactive CLI setup",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-ping": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ntfy",
    "notifications",
    "alerts",
    "cli",
    "hooks",
    "developer-tools",
    "productivity"
  ],
  "author": "singhsameer2891-pixel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/singhsameer2891-pixel/claude-ping.git"
  },
  "bugs": {
    "url": "https://github.com/singhsameer2891-pixel/claude-ping/issues"
  },
  "homepage": "https://github.com/singhsameer2891-pixel/claude-ping#readme",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
